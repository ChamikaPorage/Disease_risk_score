# 5. Main simulation settings
############################################################

N <- 1000
R <- 10000
seed <- 2025
delta <- log(2)

# Fixed population truths
truth_hajage_B <- 0.073
truth_wd_setup1 <- 0.227

# Hajage B parameters

alpha0_B <- -1.5
beta0_B  <- -2
gamma_B  <- log(1.5)

############################################################
# 6. Generate datasets
############################################################

cat("\nGenerating Hajage DGP B datasets...\n")
datasets_B <- gen_data_hajage_B(
  N = N,
  seed = seed,
  n_rep = R,
  alpha0 = alpha0_B,
  beta0 = beta0_B,
  gamma = gamma_B,
  
  delta = delta
)

cat("\nGenerating Witte & Didelez Setup 1 datasets...\n")
datasets_WD <- gen_data_wd_setup1(
  N = N,
  seed = seed,
  n_rep = R,
  delta = delta
)

############################################################
# 7. Run simulations
############################################################

cat("\n#############################\n")
cat("# Simulation: Hajage DGP B\n")
cat("#############################\n")

res_B <- run_one_dgp(
  datasets = datasets_B,
  dgp_name = "Hajage_B",
  truth = truth_hajage_B,
  N = N
)

cat("\n#############################\n")
cat("# Simulation: Witte & Didelez Setup 1\n")
cat("#############################\n")

res_WD <- run_one_dgp(
  datasets = datasets_WD,
  dgp_name = "Witte_Didelez_Setup1",
  truth = truth_wd_setup1,
  N = N
)

############################################################
# 8. Combine and summarize
############################################################

res_all <- bind_rows(res_B, res_WD)

summary_all <- bind_rows(
  lapply(
    split(res_all, list(res_all$dgp, res_all$estimator), drop = TRUE),
    summarize_results
  )
)

cat("\nFinal summary:\n")
print(round_df(summary_all, 3))

