#read data from dfmale.csv and for_table8.csv
datat <- read.csv(file = "...../Paper3_Disease risk score/Simulation_study/Simulation_new/Empirical analysis/final_df.csv")

#covariates
X.matrix <- model.matrix(smoking ~ gender + age + race + army.service + edu + married.living.with.partner + income.to.poverty + birth.country + family.size , data = datat)
dat.X <- as.data.frame(X.matrix)
dat.X <- dat.X[,-1]
colnames(dat.X)
dat <- cbind(datat$smoking, datat$HTN, dat.X)
names(dat)<- c("smoking", "HTN", LETTERS[1:15])

#PS MODELS
clip01 <- function(p, eps = 1e-6) {
  pmin(pmax(p, eps), 1 - eps)
}

#PS
mod.ps <- glm(smoking ~ A+B+C+D+E+F+G+H+I+J+K+L+M+N+O, family = binomial, data = dat)
ps <- fitted.values(mod.ps, type = "response") 
datat$ps <- ps
ps <- clip01(ps)

#Checking for overlap estimation
datat$smoking_f <- factor(
  datat$smoking,
  levels = c(0, 1),
  labels = c("Non-smokers", "Smokers")
)

ggplot(datat, aes(x = ps)) +
  geom_histogram(
    data = subset(datat, smoking_f == "Non-smokers"),
    aes(y = after_stat(count), fill = smoking_f),
    bins = 30,
    color = "black"
  ) +
  geom_histogram(
    data = subset(datat, smoking_f == "Smokers"),
    aes(y = -after_stat(count), fill = smoking_f),
    bins = 30,
    color = "black"
  ) +
  coord_flip() +
  scale_fill_manual(
    values = c(
      "Non-smokers" = "grey70",
