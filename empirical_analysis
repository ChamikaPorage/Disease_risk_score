clip01 <- function(p, lo = 1e-6, hi = 1 - 1e-6) {
  pmin(pmax(p, lo), hi)
}

expit <- function(x) {
  1 / (1 + exp(-x))
}

safe_coef <- function(fit) {
  b <- as.numeric(coef(fit))
  if (anyNA(b) || any(!is.finite(b))) {
    stop("Non-estimable coefficients detected.")
  }
  b
}

make_group_full_rank <- function(X, Tt, tol = 1e-7) {
  q_all <- qr(X, tol = tol)
  q_1   <- qr(X[Tt == 1, , drop = FALSE], tol = tol)
  q_0   <- qr(X[Tt == 0, , drop = FALSE], tol = tol)
  
  keep <- Reduce(intersect, list(
    q_all$pivot[seq_len(q_all$rank)],
    q_1$pivot[seq_len(q_1$rank)],
    q_0$pivot[seq_len(q_0$rank)]
  ))
  
  X[, sort(keep), drop = FALSE]
}

make_full_rank <- function(X, tol = 1e-7) {
  q <- qr(X, tol = tol)
  X[, q$pivot[seq_len(q$rank)], drop = FALSE]
}

add_ci <- function(estimator, tau_hat, se_tau) {
  z <- qnorm(0.975)
  data.frame(
    estimator = estimator,
    estimate = tau_hat,
    sandwich_se = se_tau,
    ci_lower_95 = tau_hat - z * se_tau,
    ci_upper_95 = tau_hat + z * se_tau
  )
}

